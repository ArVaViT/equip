# Environment variables
.env
.env.*
!.env.example
.env.local
.env.*.local
# Scratch files used when pulling envs for diagnostics — never commit
*.env.*.check
*.env.check
backend/backend/
frontend/frontend/

# Local scratch
.tmp-commit-msg.txt
.commit-msg.tmp

# Cursor IDE local rules + settings — referenced by CLAUDE.md as canonical
# conventions but deliberately kept out of git (decision reverted in 0aa5aef
# back in 2026-04). Each contributor maintains their own.
.cursor/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# CI virtual environments
.ci-venv*/

# TypeScript incremental build
*.tsbuildinfo

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

