*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Logs
*.log

# Temp files
commit-msg.txt
*.dump

# Secrets and keys (never commit)
*.pem
*.p12
credentials.json
serviceAccountKey.json
secrets/

# Editor / assistant scratchpads — anyone is welcome to use whatever IDE
# or AI helper they want, just keep its scratch files out of the repo.
# Add tool-specific paths to your own ~/.gitignore_global instead of
# polluting this list.

.vercel

# Local agent tooling scratchpad (MCP/automation helpers)
agent-tools/

# Ad-hoc one-shot backfill scripts — keep out of source control to
# avoid drift; the durable equivalent is the registry-driven hook.
backend/scripts/backfill_one_course.py

# Local REST Client (.http) scratch directory. Lives in the workspace
# but is personal — never tracked. Pre-existing rule preserved for
# the older `*.local.http` pattern.
http/
http/*.local.http

# Per-Python-version venvs (e.g. backend/venv-312 for the project-target 3.12)
backend/venv-*/

# Supabase CLI local cache
supabase/.temp/
