# Frontend environment variables
# ------------------------------------------------------------------------------
# Copy to .env.local (which is gitignored) and fill in real values.
# Only variables prefixed with `VITE_` are exposed to the browser bundle.
# ------------------------------------------------------------------------------

# URL of the FastAPI backend. In production this is the deployed API domain;
# in local development it's typically http://localhost:8000.
VITE_API_URL=http://localhost:8000

# Supabase project URL. Safe to expose — matches the one in the backend.
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (publishable) key. Safe to expose. DO NOT use the service-role
# key here — it would grant browser clients unrestricted DB access.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional — Datadog RUM (Real User Monitoring + Session Replay).
# Both APPLICATION_ID and CLIENT_TOKEN must be set for init to run;
# leave unset in dev to avoid shipping events to a dashboard nobody reads.
# Get values from https://app.datadoghq.com → UX Monitoring → RUM Applications.
# VITE_DATADOG_APPLICATION_ID=00000000-0000-0000-0000-000000000000
# VITE_DATADOG_CLIENT_TOKEN=pubXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# VITE_DATADOG_SITE=us5.datadoghq.com
# VITE_DATADOG_SERVICE=equip-frontend
# VITE_DATADOG_ENV=production
