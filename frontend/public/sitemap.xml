<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static sitemap for equipbible.com.

  Only public-facing routes are listed (any deep-linked authenticated
  pages are excluded by robots.txt anyway). Course detail pages are
  intentionally not enumerated — published courses are listed and
  internally linked from /courses, which is sufficient discovery for
  Googlebot. If the catalog grows past ~100 courses a dynamic sitemap
  generator can be added later.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://equipbible.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://equipbible.com/courses</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://equipbible.com/register</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://equipbible.com/login</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>https://equipbible.com/forgot-password</loc>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
</urlset>
